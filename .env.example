# HSR Discord Bot — environment variables
# Either fill these in via your deploy host's secret manager (Railway/Fly/systemd EnvironmentFile/etc),
# OR drop a config.json in the project root with the same keys (legacy).
# Env wins when both exist.

# === REQUIRED ===
# Discord bot token (production)
TOKEN=

# === HIGHLY RECOMMENDED ===
# Discord bot token (dev) — used when NODE_ENV=dev
TEST_TOKEN=
# Discord webhook URLs for ops/log channels
CMDWEBHOOK=
JLWEBHOOK=
LOGWEBHOOK=
FBWEBHOOK=
ERRWEBHOOK=
# Auth token for stats / external API
AUTHTOKEN=
# HTTP port for the in-bot stats server (default 3001)
WEBSERVER_PORT=3001
# Comma-separated Discord user IDs allowed to use dev commands
DEVIDS=111111111111111111,222222222222222222

# === Plan A/B/C — web-login integration ===
# Public URL of the web-login Next.js app (Vercel deployment, no trailing slash)
WEB_LOGIN_URL=https://your-web-login.vercel.app
# Supabase project URL (https://xxxxx.supabase.co)
SUPABASE_URL=
# Supabase service_role key (server-side only — NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=
# Cookie decryption key — MUST match SESSION_SECRET in web-login .env
WEB_LOGIN_SESSION_SECRET=

# === Optional — IP-block proxy for Hoyoverse login ===
# Generic outbound HTTP(S) proxy URL (e.g. http://user:pass@proxy.example.com:8080)
PROXY_URL=
# Vercel-hosted login proxy API base URL (alternative to PROXY_URL)
PROXY_API_URL=
# Bearer token for PROXY_API_URL
PROXY_API_TOKEN=

# === Optional — runtime ===
# Set to "dev" to use TEST_TOKEN instead of TOKEN
# NODE_ENV=production
